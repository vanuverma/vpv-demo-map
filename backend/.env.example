# Port the Express server listens on (defaults to 3000)
PORT=3000

# Allowed CORS origin – should match the Vite dev server URL
CORS_ORIGIN=http://localhost:5173

# ── Auth0 ────────────────────────────────────────────────────────────────────
# Auth0 tenant domain  (e.g. dev-xxxx.us.auth0.com)
AUTH0_DOMAIN=vpv-demo-map.au.auth0.com

# Auth0 API audience – must match the identifier of the API registered in Auth0
AUTH0_AUDIENCE=https://vpv-demo-map-apis.com.au