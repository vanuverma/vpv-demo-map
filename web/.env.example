# Google Maps API key (required for the map to load)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps Map ID (optional – used for Advanced Markers; defaults to DEMO_MAP_ID)
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# Backend API base URL (defaults to http://localhost:3000)
VITE_API_BASE_URL=http://localhost:3000

# Set to 'false' to show the alternative map provider instead of Google Maps
VITE_SHOW_GOOGLE_MAP=true

# ── Auth0 ────────────────────────────────────────────────────────────────────
# Auth0 tenant domain  (e.g. dev-xxxx.us.auth0.com)
VITE_AUTH0_DOMAIN=vpv-demo-map.au.auth0.com

# Auth0 Single-Page Application client ID
VITE_AUTH0_CLIENT_ID=auth0_client_id

# Auth0 API audience (must match the identifier of the API registered in Auth0)
VITE_AUTH0_AUDIENCE=https://vpv-demo-map-apis.com.au
