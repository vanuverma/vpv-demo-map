# Google Maps API key (required for the map to load)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps Map ID (optional – used for Advanced Markers; defaults to DEMO_MAP_ID)
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# Backend API base URL (defaults to http://localhost:3000)
VITE_API_BASE_URL=http://localhost:3000

# User e-mail used to scope saved locations (defaults to demo@example.com)
VITE_USER_EMAIL=demo@example.com

# Set to 'false' to show the alternative map provider instead of Google Maps
VITE_SHOW_GOOGLE_MAP=true
